#!/bin/bash
# check-write-permission.sh — Gate writes to story-driven flow only
#
# Allows writes if:
# 1. File is in .craft/ or .claude/ directory
# 2. dev_mode: true in .craft/settings.yaml
# 3. CRAFT_WRITE_ENABLED=true in .craft/.global-state
#
# Otherwise blocks with guidance to use craft workflow
#
# Output format: PreToolUse hooks use exit 0 for allow,
# hookSpecificOutput JSON with permissionDecision for deny.

# Fail open on ANY unexpected error — never crash a write gate
set +e
trap 'exit 0' ERR

# Require jq for JSON parsing
if ! command -v jq &> /dev/null; then
  exit 0
fi

# Read tool input from stdin into temp file (avoids shell variable size limits)
_tmpfile=$(mktemp 2>/dev/null || echo "/tmp/craft-write-check-$$")
cat > "$_tmpfile"

# Extract file path from tool input
file_path=$(jq -r '.tool_input.file_path // .tool_input.filePath // ""' < "$_tmpfile" 2>/dev/null)

# If we can't determine file path, allow (fail open for safety)
if [ -z "$file_path" ]; then
  rm -f "$_tmpfile"
  exit 0
fi

# Get the working directory from input
cwd=$(jq -r '.cwd // "."' < "$_tmpfile" 2>/dev/null)
rm -f "$_tmpfile"

# Check 1: Is this a .craft/ file? Always allow
if [[ "$file_path" == *"/.craft/"* ]] || [[ "$file_path" == ".craft/"* ]]; then
  exit 0
fi

# Check 1b: Is this Claude's own internal storage? Always allow
if [[ "$file_path" == *"/.claude/"* ]]; then
  exit 0
fi

# Resolve project root using shared monorepo-aware resolution
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/find-project-root.sh" 2>/dev/null || true

# If no .craft directory found, allow (not a craft project)
if [ -z "$PROJECT_ROOT" ] || [ ! -d "$PROJECT_ROOT/.craft" ]; then
  exit 0
fi

# Check 2: Is the file outside the project? Always allow
# Only gate writes to files inside the project workspace
case "$file_path" in
  "$PROJECT_ROOT"*) ;; # inside project — continue checks
  /*) exit 0 ;;         # absolute path outside project — allow
esac
# Relative paths: resolve against cwd, check if inside project
if [[ "$file_path" != /* ]]; then
  resolved_path="$cwd/$file_path"
  case "$resolved_path" in
    "$PROJECT_ROOT"*) ;; # inside project — continue checks
    *) exit 0 ;;         # outside project — allow
  esac
fi

# Check 3: dev_mode enabled?
settings_file="$PROJECT_ROOT/.craft/settings.yaml"
if [ -f "$settings_file" ]; then
  dev_mode=$(grep "^dev_mode:" "$settings_file" 2>/dev/null | awk '{print $2}' | tr -d '\r')
  if [ "$dev_mode" = "true" ]; then
    exit 0
  fi
fi

# Check 3: CRAFT_WRITE_ENABLED in global state?
state_file="$PROJECT_ROOT/.craft/.global-state"
if [ -f "$state_file" ]; then
  source "$state_file"
  if [ "$CRAFT_WRITE_ENABLED" = "true" ]; then
    exit 0
  fi
fi

# Block the write — hookSpecificOutput format for PreToolUse
cat << 'DECISION'
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "deny",
    "permissionDecisionReason": "All edits must go through a story. Use /craft:story-new to capture this change, or /craft:story-implement to work on an existing story."
  }
}
DECISION
